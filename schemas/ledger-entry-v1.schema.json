{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/platform-core/ledger-entry-v1.json",
  "title": "Sustainable Catalyst Ledger Entry",
  "type": "object",
  "required": [
    "sequence",
    "record_type",
    "record_id",
    "action",
    "actor",
    "payload_hash",
    "entry_hash"
  ],
  "properties": {
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string"
    },
    "record_type": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "previous_entry_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "entry_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "payload": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
