{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/platform-core/evidence-record-v1.json",
  "title": "Sustainable Catalyst Evidence Record",
  "type": "object",
  "required": [
    "evidence_type",
    "stance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "evidence_type": {
      "type": "string"
    },
    "stance": {
      "enum": [
        "supports",
        "contradicts",
        "contextualizes",
        "neutral"
      ]
    },
    "claim_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "subject_entity_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_entity_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_snapshot_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "relationship_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "calculation_trace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "statement": {
      "type": [
        "string",
        "null"
      ]
    },
    "methodology": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "review_status": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  }
}
