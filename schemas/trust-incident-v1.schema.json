{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/platform-core/trust-incident-v1.json",
  "title": "Sustainable Catalyst Trust Incident",
  "type": "object",
  "required": [
    "title",
    "severity",
    "status",
    "summary",
    "started_at",
    "detected_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "enum": [
        "investigating",
        "identified",
        "monitoring",
        "resolved"
      ]
    },
    "summary": {
      "type": "string"
    },
    "impact": {
      "type": [
        "string",
        "null"
      ]
    },
    "root_cause": {
      "type": [
        "string",
        "null"
      ]
    },
    "remediation": {
      "type": [
        "string",
        "null"
      ]
    },
    "affected_entity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "public": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object"
    }
  }
}
