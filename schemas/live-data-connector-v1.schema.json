{
  "$id": "https://sustainablecatalyst.com/schemas/live-data-connector-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "adapter": {
      "maxLength": 180,
      "minLength": 1,
      "title": "Adapter",
      "type": "string"
    },
    "base_url": {
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "title": "Base Url",
      "type": "string"
    },
    "capabilities": {
      "items": {
        "type": "string"
      },
      "title": "Capabilities",
      "type": "array"
    },
    "configuration": {
      "additionalProperties": true,
      "title": "Configuration",
      "type": "object"
    },
    "description": {
      "anyOf": [
        {
          "maxLength": 20000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "domain": {
      "pattern": "^[a-z0-9][a-z0-9_-]{1,99}$",
      "title": "Domain",
      "type": "string"
    },
    "enabled": {
      "default": true,
      "title": "Enabled",
      "type": "boolean"
    },
    "freshness_window_seconds": {
      "default": 86400,
      "maximum": 31536000,
      "minimum": 60,
      "title": "Freshness Window Seconds",
      "type": "integer"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9._-]{1,179}$",
      "title": "Id",
      "type": "string"
    },
    "max_response_bytes": {
      "default": 5242880,
      "maximum": 52428800,
      "minimum": 1024,
      "title": "Max Response Bytes",
      "type": "integer"
    },
    "name": {
      "maxLength": 300,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "public": {
      "default": true,
      "title": "Public",
      "type": "boolean"
    },
    "refresh_policy": {
      "default": "manual",
      "maxLength": 100,
      "title": "Refresh Policy",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "maxLength": 30,
      "title": "Schema Version",
      "type": "string"
    },
    "source_id": {
      "maxLength": 150,
      "minLength": 2,
      "title": "Source Id",
      "type": "string"
    },
    "status": {
      "default": "active",
      "enum": [
        "active",
        "paused",
        "deprecated",
        "disabled"
      ],
      "title": "Status",
      "type": "string"
    },
    "timeout_seconds": {
      "default": 20,
      "maximum": 120,
      "minimum": 1,
      "title": "Timeout Seconds",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "source_id",
    "name",
    "domain",
    "adapter",
    "base_url"
  ],
  "title": "LiveDataConnectorCreate",
  "type": "object"
}
