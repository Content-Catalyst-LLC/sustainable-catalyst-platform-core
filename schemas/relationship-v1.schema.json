{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/platform-core/relationship-v1.json",
  "title": "Sustainable Catalyst Relationship",
  "type": "object",
  "required": [
    "subject_id",
    "predicate",
    "object_id"
  ],
  "properties": {
    "subject_id": {
      "type": "string"
    },
    "predicate": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "object_id": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
