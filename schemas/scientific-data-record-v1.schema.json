{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/scientific-data-record-v1.schema.json",
  "title": "Sustainable Catalyst Scientific Data Record",
  "type": "object",
  "required": [
    "id",
    "source_record_id",
    "record_type",
    "discipline",
    "title",
    "content_hash"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "connector_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "source_record_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "record_type": {
      "type": "string"
    },
    "discipline": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "dataset_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "collection": {
      "type": [
        "string",
        "null"
      ]
    },
    "mission": {
      "type": [
        "string",
        "null"
      ]
    },
    "instrument": {
      "type": [
        "string",
        "null"
      ]
    },
    "target": {
      "type": [
        "string",
        "null"
      ]
    },
    "doi": {
      "type": [
        "string",
        "null"
      ]
    },
    "access_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "landing_page_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "geometry": {
      "type": [
        "object",
        "null"
      ]
    },
    "observation_start": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "observation_end": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "identifiers": {
      "type": "object"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "variables": {
      "type": "array"
    },
    "file_formats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality_status": {
      "type": "string"
    },
    "license_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "attribution": {
      "type": [
        "string",
        "null"
      ]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "metadata": {
      "type": "object"
    },
    "public": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
