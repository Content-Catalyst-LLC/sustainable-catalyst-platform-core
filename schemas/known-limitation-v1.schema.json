{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/platform-core/known-limitation-v1.json",
  "title": "Sustainable Catalyst Known Limitation",
  "type": "object",
  "required": [
    "domain",
    "title",
    "description",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "impact": {
      "type": [
        "string",
        "null"
      ]
    },
    "mitigation": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "active",
        "mitigated",
        "retired"
      ]
    },
    "affected_entity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_after": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "public": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object"
    }
  }
}
