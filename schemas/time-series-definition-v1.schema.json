{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/time-series-definition-v1.schema.json",
  "title": "Sustainable Catalyst Time-Series Definition",
  "type": "object",
  "required": ["id", "source_id", "connector_id", "metric", "title", "domain", "dimension_hash"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_id": {"type": "string"},
    "connector_id": {"type": "string"},
    "metric": {"type": "string"},
    "title": {"type": "string"},
    "description": {"type": ["string", "null"]},
    "dataset_id": {"type": ["string", "null"]},
    "domain": {"type": "string"},
    "unit": {"type": ["string", "null"]},
    "frequency": {"type": ["string", "null"]},
    "geography_code": {"type": ["string", "null"]},
    "dimensions": {"type": "object"},
    "dimension_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "license_name": {"type": ["string", "null"]},
    "attribution": {"type": ["string", "null"]},
    "public": {"type": "boolean"}
  },
  "additionalProperties": true
}
