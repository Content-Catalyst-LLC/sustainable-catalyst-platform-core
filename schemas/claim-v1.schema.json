{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/platform-core/claim-v1.json",
  "title": "Sustainable Catalyst Claim Record",
  "type": "object",
  "required": [
    "claim_text",
    "claim_type"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "claim_text": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "type": "string"
    },
    "subject_entity_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string"
    },
    "visibility": {
      "enum": [
        "public",
        "internal",
        "private"
      ]
    },
    "language": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
