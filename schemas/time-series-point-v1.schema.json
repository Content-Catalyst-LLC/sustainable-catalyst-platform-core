{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/time-series-point-v1.schema.json",
  "title": "Sustainable Catalyst Time-Series Point",
  "type": "object",
  "required": ["id", "series_id", "observed_at", "partition_key", "point_hash"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "series_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "observation_id": {"type": ["string", "null"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "partition_key": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$"},
    "value_number": {"type": ["number", "null"]},
    "value_text": {"type": ["string", "null"]},
    "quality_status": {"type": "string"},
    "freshness_status": {"type": "string"},
    "dimensions": {"type": "object"},
    "point_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "public": {"type": "boolean"}
  },
  "additionalProperties": true
}
