{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/scientific-data-asset-v1.schema.json",
  "title": "Sustainable Catalyst Scientific Data Asset",
  "type": "object",
  "required": ["id", "source_id", "title", "asset_role", "format", "href", "storage_mode"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "scientific_record_id": {"type": ["string", "null"]},
    "source_id": {"type": "string"},
    "connector_id": {"type": ["string", "null"]},
    "dataset_id": {"type": ["string", "null"]},
    "title": {"type": "string"},
    "asset_role": {"type": "string"},
    "media_type": {"type": ["string", "null"]},
    "format": {"type": "string"},
    "href": {"type": "string", "format": "uri"},
    "storage_mode": {"type": "string", "enum": ["remote", "link_only", "managed_object", "cached"]},
    "size_bytes": {"type": ["integer", "null"], "minimum": 0},
    "checksum": {"type": ["string", "null"]},
    "stac_roles": {"type": "array", "items": {"type": "string"}},
    "variables": {"type": "array"},
    "spatial_extent": {"type": "array"},
    "temporal_extent": {"type": "array"},
    "license_name": {"type": ["string", "null"]},
    "attribution": {"type": ["string", "null"]},
    "metadata": {"type": "object"},
    "public": {"type": "boolean"}
  },
  "additionalProperties": true
}
