{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/platform-core/signature-dossier-v1.json",
  "title": "Sustainable Catalyst Signature Dossier",
  "type": "object",
  "required": [
    "id",
    "title",
    "purpose",
    "version",
    "status",
    "visibility"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "workflow_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "subject_entity_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "finalized",
        "superseded"
      ]
    },
    "visibility": {
      "enum": [
        "public",
        "internal",
        "private"
      ]
    },
    "dossier_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "signature_algorithm": {
      "type": [
        "string",
        "null"
      ]
    },
    "platform_signature": {
      "type": [
        "string",
        "null"
      ]
    },
    "signing_key_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "signed_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "signed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "records": {
      "type": "array"
    },
    "approvals": {
      "type": "array"
    },
    "metadata": {
      "type": "object"
    }
  }
}
