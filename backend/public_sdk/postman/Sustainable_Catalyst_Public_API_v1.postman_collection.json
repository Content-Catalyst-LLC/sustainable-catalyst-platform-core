{
  "info": {
    "name": "Sustainable Catalyst Unified Public API v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Registry, graph, evidence, ledger, trust, workflow, signature dossier, usage, and webhook endpoints."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://YOUR-PLATFORM-CORE.onrender.com"
    },
    {
      "key": "apiKey",
      "value": "scpk_your_key"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{apiKey}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/status"
      }
    },
    {
      "name": "Entities",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/entities?entity_type=product"
      }
    },
    {
      "name": "Knowledge Graph",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/graph/sc:product:research-librarian?depth=2"
      }
    },
    {
      "name": "Claims",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/claims"
      }
    },
    {
      "name": "Verify Ledger",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/ledger/verify"
      }
    },
    {
      "name": "Developer Identity",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/developer/me"
      }
    },
    {
      "name": "Usage",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/developer/usage?days=30"
      }
    },
    {
      "name": "Trust Status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/trust/status"
      }
    },
    {
      "name": "Trust Evaluations",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/trust/evaluations"
      }
    },
    {
      "name": "Trust Incidents",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/trust/incidents"
      }
    },
    {
      "name": "Known Limitations",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/trust/limitations"
      }
    },
    {
      "name": "Workflow Definitions",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/workflow-definitions"
      }
    },
    {
      "name": "Workflow Run",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/workflow-runs/sc:workflow-run:YOUR_ID"
      }
    },
    {
      "name": "Signature Dossiers",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/dossiers"
      }
    },
    {
      "name": "Signature Dossier",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/dossiers/sc:dossier:YOUR_ID"
      }
    },
    {
      "name": "Verify Signature Dossier",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/dossiers/sc:dossier:YOUR_ID/verify"
      }
    },
    {
      "name": "Free Live Data Gateway",
      "item": [
        {
          "name": "Live Sources",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/live/sources"
          }
        },
        {
          "name": "Live Connectors",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/live/connectors"
          }
        },
        {
          "name": "Latest Earthquakes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/live/observations/latest?connector_id=usgs.earthquakes"
          }
        },
        {
          "name": "World Bank Timeseries",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/live/timeseries?metric=SP.POP.TOTL&source_id=world-bank"
          }
        },
        {
          "name": "Observation Provenance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/live/provenance/{{observationId}}"
          }
        }
      ]
    },
    {
      "name": "International Law and UN",
      "item": [
        {
          "name": "List international-law records",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/international-law/records?limit=25",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "international-law",
                "records"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25"
                }
              ]
            }
          }
        },
        {
          "name": "Authority taxonomy",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/international-law/authority-taxonomy",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "international-law",
                "authority-taxonomy"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Scientific Data",
      "item": [
        {
          "name": "List scientific records",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/science/records?limit=25",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "science",
                "records"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25"
                }
              ]
            }
          }
        },
        {
          "name": "Filter astronomy records",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/science/records?discipline=astronomy&limit=25",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "science",
                "records"
              ],
              "query": [
                {
                  "key": "discipline",
                  "value": "astronomy"
                },
                {
                  "key": "limit",
                  "value": "25"
                }
              ]
            }
          }
        },
        {
          "name": "Scientific record types",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/science/record-types",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "science",
                "record-types"
              ]
            }
          }
        }
      ]
    }
  ]
}
