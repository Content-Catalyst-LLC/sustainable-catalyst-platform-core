SC_CORE_RELIEFWEB_APPNAME=
SC_CORE_HDX_HAPI_APP_IDENTIFIER=sustainable-catalyst-platform-core
SC_CORE_UHRI_API_URL=
SC_CORE_UN_POPULATION_BEARER_TOKEN=
# Scientific Data Connector Pack v2.7.2
# NASA Open APIs accept DEMO_KEY for development; register a free key for sustained use.
SC_CORE_NASA_API_KEY=DEMO_KEY
# Optional free NCBI key for increased request allowance.
SC_CORE_NCBI_API_KEY=
# Required only for the free-registration Materials Project connector.
SC_CORE_MATERIALS_PROJECT_API_KEY=


