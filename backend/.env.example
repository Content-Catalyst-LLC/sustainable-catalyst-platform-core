SC_CORE_GATEWAY_MAX_REQUEST_BYTES=2000000
SC_CORE_GATEWAY_MAX_RESPONSE_BYTES=8000000
SC_CORE_GATEWAY_CIRCUIT_FAILURES=3
SC_CORE_GATEWAY_CIRCUIT_COOLDOWN=30
