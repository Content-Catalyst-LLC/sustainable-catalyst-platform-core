SC_CORE_ENVIRONMENT=development
SC_CORE_DATABASE_URL=sqlite:///./platform_core.db
SC_CORE_WRITE_API_KEY=change-me
SC_CORE_PUBLIC_READS=true
SC_CORE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8090
SC_CORE_LOG_LEVEL=INFO
SC_CORE_MAX_GRAPH_DEPTH=4
SC_CORE_PAGE_SIZE_MAX=200
SC_CORE_EXPLORER_ENABLED=true
SC_CORE_EVIDENCE_EXPLORER_ENABLED=true
SC_CORE_SNAPSHOT_EXCERPT_MAX=1200
SC_CORE_PUBLIC_API_ENABLED=true
SC_CORE_DEVELOPER_PORTAL_ENABLED=true
SC_CORE_PUBLIC_API_DEFAULT_PLAN=free
SC_CORE_API_LOG_SALT=change-to-a-long-random-secret
SC_CORE_WEBHOOK_SIGNING_SECRET=change-to-a-different-long-random-secret
SC_CORE_WEBHOOK_DELIVERY_TIMEOUT=10
SC_CORE_TRUST_CENTER_ENABLED=true
SC_CORE_TRUST_PUBLIC_STATUS_ENABLED=true
SC_CORE_TRUST_STALE_AFTER_DAYS=90

SC_CORE_WORKFLOW_ENGINE_ENABLED=true
SC_CORE_DOSSIER_CENTER_ENABLED=true
SC_CORE_DOSSIER_SIGNING_SECRET=<generate-a-long-random-secret>
SC_CORE_DOSSIER_SIGNING_KEY_ID=sc-platform-core-production
SC_CORE_DOSSIER_REQUIRED_APPROVALS=1
SC_CORE_DOSSIER_MAX_RECORDS=500
