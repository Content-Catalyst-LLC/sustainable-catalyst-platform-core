# Free Live Data Gateway v2.7.0
SC_CORE_LIVE_DATA_ENABLED=true
SC_CORE_LIVE_DATA_INGEST_ENABLED=true
SC_CORE_LIVE_DATA_STRICT_FREE_SOURCES=true
SC_CORE_LIVE_DATA_USER_AGENT=SustainableCatalystPlatformCore/2.7.3 (+https://sustainablecatalyst.com/contact/)
SC_CORE_LIVE_DATA_TIMEOUT_SECONDS=20
SC_CORE_LIVE_DATA_MAX_RESPONSE_BYTES=12582912
SC_CORE_LIVE_DATA_RAW_PAYLOAD_MAX_BYTES=1048576

# Optional free registered key. Without it, only the FRED connector reports
# credential_required; all other seeded connectors remain configured.
SC_CORE_FRED_API_KEY=

